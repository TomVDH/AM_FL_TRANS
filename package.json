{
  "name": "am-translations-helper",
  "version": "3.1.0",
  "description": "A React TypeScript application for assisting with translation workflows, supporting Excel file uploads and manual text input.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:https": "next dev --experimental-https",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "excel-to-json": "node scripts/convert/excel-to-json.js",
    "excel-to-csv": "node scripts/convert/excel-to-csv.js",
    "csv-only": "node scripts/convert/excel-to-csv.js",
    "clean": "rm -rf .next node_modules/.cache",
    "clean-build": "npm run clean && npm run build",
    "fresh-start": "rm -rf .next node_modules package-lock.json && npm install && npm run dev",
    "build-and-launch": "npm run clean && npm run build && npm run start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "exceljs": "^4.4.0",
    "gsap": "^3.13.0",
    "next": "^15.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.17.0",
    "@types/react": "18.3.23",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "5.8.3",
    "storybook": "^10.2.0",
    "@storybook/nextjs-vite": "^10.2.0",
    "@chromatic-com/storybook": "^5.0.0",
    "@storybook/addon-vitest": "^10.2.0",
    "@storybook/addon-a11y": "^10.2.0",
    "@storybook/addon-docs": "^10.2.0",
    "@storybook/addon-onboarding": "^10.2.0",
    "vite": "^7.3.1",
    "eslint-plugin-storybook": "^10.2.0",
    "vitest": "^4.0.17",
    "playwright": "^1.57.0",
    "@vitest/browser-playwright": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.17"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
